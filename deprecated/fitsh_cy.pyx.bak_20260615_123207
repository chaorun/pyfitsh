    @staticmethod
    def decode_maskinfo(hdu):
        """Decode MASKINFO from FITS HDU header into uint8 mask array.

        Equivalent to the C function mask_read_from_header().
        Returns numpy array shape (NAXIS2, NAXIS1), zero where no mask.

        Args:
            hdu: astropy.io.fits HDU (e.g. hdul[0])
        """
        import re
        import numpy as np
        FITS_MASK_MAX = 0x7F

        header = hdu.header
        sx = header['NAXIS1']
        sy = header['NAXIS2']

        lines = []
        for card in header.cards:
            if card.keyword == 'MASKINFO':
                img = card.image
                start = img.index("'") + 1
                end = img.rindex("'")
                lines.append(img[start:end])
        if not lines:
            return np.zeros((sy, sx), dtype=np.uint8)

        mask = np.zeros((sy, sx), dtype=np.uint8)
        xp, yp, ud, d = 0, 0, 0, 0x01
        P = re.compile(r'^([+-]?\d+)(?:,([+-]?\d+)(?::([+-]?\d+)(?:,([+-]?\d+))?)?)?$')

        for line in lines:
            for tok in line.split():
                m = P.match(tok)
                if not m:
                    continue
                g = m.groups()
                if g[1] is None:
                    v = int(g[0])
                    if v > 0: ud = 1
                    elif v < 0: d = (-v) & FITS_MASK_MAX
                    else: ud = 0
                    continue
                x, y = int(g[0]), int(g[1])
                if g[2] is None:
                    lx = ly = 1
                elif g[3] is None:
                    lx = int(g[2])
                    if lx > 1: ly = 1
                    elif lx < -1: ly = -lx; lx = 1
                    else: lx = ly = 1
                else:
                    lx, ly = int(g[2]), int(g[3])

                if lx <= 0 or ly <= 0:
                    continue
                if ud:
                    x += xp; y += yp
                if x < 0: lx += x; x = 0
                if y < 0: ly += y; y = 0
                if x + lx > sx: lx = sx - x
                if y + ly > sy: ly = sy - y
                xp, yp = x, y
                if lx > 0 and ly > 0:
                    mask[y:y+ly, x:x+lx] |= d

        return mask


cdef class _ShiftOp:
    """Simple pixel shift (matching --shift dx,dy in fitrans CLI)."""
    cdef double _dx, _dy
    def __init__(self, dx, dy):
        self._dx = dx; self._dy = dy
    def apply(self, img_data, img_mask=None, weight=None):
